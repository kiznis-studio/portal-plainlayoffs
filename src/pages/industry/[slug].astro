---
import Base from '../../layouts/Base.astro';
import { getIndustry, getIndustryEmployers, getIndustryNotices } from '../../lib/db';
const { slug } = Astro.params;
if (!slug) return Astro.redirect('/industries/');
const industry = await getIndustry(slug);
if (!industry) return Astro.redirect('/industries/');
const employers = await getIndustryEmployers(slug, 20);
const notices = await getIndustryNotices(slug, 20);
function fmt(d: string|null) { return d ? new Date(d+'T12:00:00Z').toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : ''; }
const title = `${industry.name} Layoffs — WARN Act Data`;
const desc = `Mass layoff data for the ${industry.name} industry: ${industry.total_notices} WARN notices, ${industry.total_workers.toLocaleString()} workers affected.`;
---
<Base title={title} description={desc} breadcrumbs={[{name:'Home',href:'/'},{name:'Industries',href:'/industries/'},{name:industry.name}]}>
  <div class="container py-8 max-w-4xl">
    <nav class="text-sm text-[var(--color-muted)] mb-3">
      <a href="/" class="hover:text-[var(--color-foreground)]">Home</a><span class="mx-2">/</span>
      <a href="/industries/" class="hover:text-[var(--color-foreground)]">Industries</a><span class="mx-2">/</span>
      <span>{industry.name}</span>
    </nav>
    <h1 class="text-3xl font-bold mb-1">{industry.name}</h1>
    <p class="text-[var(--color-muted)] mb-6">{industry.naics && `NAICS ${industry.naics} · `}Industry Layoff Tracker</p>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-8">
      <div class="p-4 rounded-lg border border-[var(--color-border)] bg-[var(--color-card)]"><p class="text-2xl font-bold text-amber-600 dark:text-amber-400">{industry.total_workers.toLocaleString()}</p><p class="text-sm text-[var(--color-muted)]">Total Workers</p></div>
      <div class="p-4 rounded-lg border border-[var(--color-border)] bg-[var(--color-card)]"><p class="text-2xl font-bold">{industry.total_notices}</p><p class="text-sm text-[var(--color-muted)]">WARN Notices</p></div>
      <div class="p-4 rounded-lg border border-[var(--color-border)] bg-[var(--color-card)]"><p class="text-2xl font-bold">{employers.length}</p><p class="text-sm text-[var(--color-muted)]">Employers</p></div>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      {employers.length > 0 && (
        <div>
          <h2 class="text-xl font-bold mb-4">Top Employers</h2>
          <div class="space-y-2">
            {employers.map((emp,i) => (
              <a href={`/employer/${emp.slug}`} class="flex items-center gap-3 p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-card)] hover:border-amber-400 transition-colors group">
                <span class="text-sm text-[var(--color-muted)] w-5 shrink-0">{i+1}</span>
                <span class="flex-1 text-sm font-medium group-hover:text-amber-600 dark:group-hover:text-amber-400 truncate">{emp.name}</span>
                <span class="text-sm font-semibold text-amber-600 dark:text-amber-400 shrink-0">{emp.total_workers.toLocaleString()}</span>
              </a>
            ))}
          </div>
        </div>
      )}
      {notices.length > 0 && (
        <div>
          <h2 class="text-xl font-bold mb-4">Recent Notices</h2>
          <div class="space-y-2">
            {notices.map(n => (
              <div class="p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-card)]">
                <div class="flex items-start justify-between gap-2">
                  <div class="flex-1 min-w-0">
                    {n.employer_slug ? <a href={`/employer/${n.employer_slug}`} class="text-sm font-medium hover:text-amber-600 dark:hover:text-amber-400 truncate block">{n.employer_name}</a> : <span class="text-sm font-medium truncate block">{n.employer_name}</span>}
                    <p class="text-xs text-[var(--color-muted)]">{n.state}{n.city && `, ${n.city}`} · {fmt(n.notice_date)}</p>
                  </div>
                  <div class="text-right shrink-0"><span class="text-sm font-semibold text-amber-600 dark:text-amber-400">{n.workers_affected.toLocaleString()}</span><p class="text-xs text-[var(--color-muted)]">workers</p></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
    <div class="mt-8 p-4 rounded-lg bg-amber-50 dark:bg-amber-900/10 border border-amber-200 dark:border-amber-800">
      <p class="text-sm text-amber-800 dark:text-amber-300">
        Concerned about AI displacement in {industry.name}? <a href="https://plainworkforce.com" target="_blank" rel="noopener" class="underline">See AI exposure scores →</a>
      </p>
    </div>
  </div>
</Base>
