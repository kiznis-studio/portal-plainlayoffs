---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found — [PortalName]" description="The page you're looking for doesn't exist.">
  <section class="py-16 md:py-24">
    <div class="max-w-xl mx-auto px-4 text-center">
      <p class="text-6xl font-bold text-[var(--color-muted)] mb-4">404</p>
      <h1 class="text-2xl font-bold text-[var(--color-text)] mb-4">Page Not Found</h1>
      <p class="text-[var(--color-text-secondary)] mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--color-primary)] text-white rounded-lg hover:opacity-90 transition-opacity font-medium"
      >
        &larr; Back to Home
      </a>
    </div>
  </section>
</Base>
