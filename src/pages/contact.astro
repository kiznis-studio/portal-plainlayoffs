---
import Base from '../layouts/Base.astro';
export const prerender = true;
const title = 'Contact PlainLayoffs — Data Corrections & Inquiries';
const description = 'Contact PlainLayoffs for data corrections, press inquiries, or general feedback about our WARN Act database.';
---
<Base title={title} description={description}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <nav class="text-sm text-gray-500 dark:text-gray-400 mb-6">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-amber-600 dark:hover:text-amber-400">Home</a></li>
        <li>/</li>
        <li class="text-gray-800 dark:text-gray-200 font-medium">Contact</li>
      </ol>
    </nav>
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6">Contact Us</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-8 text-lg">Have a data correction, press inquiry, or general question? We'd love to hear from you.</p>

    <div class="grid sm:grid-cols-2 gap-6 mb-10">
      <div class="bg-amber-50 dark:bg-amber-900/20 rounded-lg p-5 border border-amber-200 dark:border-amber-800">
        <h3 class="font-semibold text-amber-800 dark:text-amber-200 mb-2">Data Corrections</h3>
        <p class="text-sm text-amber-700 dark:text-amber-300">Spot an error in our WARN Act data? Let us know the employer name, date, and the correction needed.</p>
      </div>
      <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-5 border border-gray-200 dark:border-gray-700">
        <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">Press & Research</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">Journalists and researchers — we're happy to provide context, data exports, or custom queries for editorial or academic purposes.</p>
      </div>
    </div>

    <form class="space-y-5" id="contact-form" novalidate>
      <div>
        <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Name</label>
        <input type="text" id="name" name="name" required autocomplete="name"
          class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent" />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Email</label>
        <input type="email" id="email" name="email" required autocomplete="email"
          class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent" />
      </div>
      <div>
        <label for="subject" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Subject</label>
        <select id="subject" name="subject"
          class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500">
          <option value="">Select a topic...</option>
          <option value="data-correction">Data Correction</option>
          <option value="press">Press / Research Inquiry</option>
          <option value="legal">Legal / Privacy Request</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Message</label>
        <textarea id="message" name="message" rows="5" required
          class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent resize-vertical"></textarea>
      </div>
      <button type="submit"
        class="w-full sm:w-auto px-8 py-3 bg-amber-600 text-white rounded-lg hover:bg-amber-700 font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-amber-500 focus:ring-offset-2">
        Send Message
      </button>
      <p id="form-status" class="text-sm text-gray-500 dark:text-gray-400 hidden"></p>
    </form>

    <script>
      const form = document.getElementById('contact-form') as HTMLFormElement;
      const status = document.getElementById('form-status');
      form?.addEventListener('submit', (e) => {
        e.preventDefault();
        if (status) {
          status.classList.remove('hidden');
          status.textContent = 'Thank you for your message. We\'ll respond within 2-3 business days.';
        }
        form.reset();
      });
    </script>
  </div>
</Base>
