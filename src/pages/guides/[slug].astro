<Base title={guide.title} description={guide.description}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 dark:text-gray-400 mb-6">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-amber-600 dark:hover:text-amber-400">Home</a></li>
        <li>/</li>
        <li class="text-gray-800 dark:text-gray-200 font-medium">Guide</li>
      </ol>
    </nav>

    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-3 text-sm text-gray-500 dark:text-gray-400 mb-4">
        <time datetime={guide.date}>{new Date(guide.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        <span>·</span>
        <span>{guide.readTime}</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4 leading-tight">{guide.title}</h1>
      <p class="text-xl text-gray-600 dark:text-gray-400 leading-relaxed">{guide.description}</p>
    </div>

    <!-- Content -->
    <article class="prose prose-gray dark:prose-invert prose-headings:font-semibold prose-a:text-amber-600 dark:prose-a:text-amber-400 prose-a:no-underline hover:prose-a:underline prose-li:my-1 max-w-none">
      <Fragment set:html={guide.content} />
    </article>

    <!-- Footer -->
    <div class="mt-10 pt-8 border-t border-gray-200 dark:border-gray-700">
      <div class="flex flex-wrap gap-4">
        <a href="/recent" class="text-amber-600 dark:text-amber-400 hover:underline text-sm">Browse Recent WARN Notices →</a>
        <a href="/states/" class="text-amber-600 dark:text-amber-400 hover:underline text-sm">View by State →</a>
        <a href="/rankings" class="text-amber-600 dark:text-amber-400 hover:underline text-sm">Top Employer Rankings →</a>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": guide.title,
    "description": guide.description,
    "datePublished": guide.date,
    "dateModified": guide.date,
    "author": { "@type": "Organization", "name": "PlainLayoffs" },
    "publisher": { "@type": "Organization", "name": "PlainLayoffs", "url": "https://plainlayoffs.com" },
    "url": `https://plainlayoffs.com/guides/${slug}`,
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://plainlayoffs.com" },
        { "@type": "ListItem", "position": 2, "name": guide.title }
      ]
    }
  })} />
</Base>
