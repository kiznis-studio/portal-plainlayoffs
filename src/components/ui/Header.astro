---
const siteName = "PlainLayoffs";
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/employers/', label: 'Employers' },
  { href: '/states/', label: 'States' },
  { href: '/industries/', label: 'Industries' },
  { href: '/rankings', label: 'Rankings' },
  { href: '/recent', label: 'Recent' },
];

function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(href.replace(/\/$/, '/'));
}
---

<header class="border-b border-[var(--color-border)] bg-[var(--color-background)] sticky top-0 z-50">
  <div class="container">
    <nav class="flex items-center justify-between h-16">
      <a href="/" class="font-bold text-xl text-amber-600 dark:text-amber-400 hover:no-underline flex items-center gap-2">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        {siteName}
      </a>
      
      <div class="hidden md:flex items-center gap-6">
        {navItems.map(item => (
          <a 
            href={item.href}
            class={`text-sm transition-colors ${isActive(item.href) ? 'text-amber-600 dark:text-amber-400 font-medium' : 'text-[var(--color-muted)] hover:text-[var(--color-foreground)]'}`}
          >
            {item.label}
          </a>
        ))}
      </div>
      
      <div class="flex items-center gap-3">
        <a href="/search" class="hidden md:flex items-center gap-2 text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          Search
        </a>
        <button 
          id="theme-toggle"
          class="p-2 rounded-lg hover:bg-[var(--color-card)] transition-colors"
          aria-label="Toggle dark mode"
        >
          <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>
        
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg hover:bg-[var(--color-card)] transition-colors" aria-label="Toggle menu">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </nav>
    
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-[var(--color-border)]">
      <div class="flex flex-col gap-1 pt-3">
        {navItems.map(item => (
          <a 
            href={item.href}
            class={`px-3 py-2 rounded-lg text-sm transition-colors ${isActive(item.href) ? 'bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400' : 'text-[var(--color-muted)] hover:bg-[var(--color-card)]'}`}
          >
            {item.label}
          </a>
        ))}
        <a href="/search" class="px-3 py-2 rounded-lg text-sm text-[var(--color-muted)] hover:bg-[var(--color-card)] transition-colors">Search</a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  const btn = document.getElementById('theme-toggle');
  if (btn) {
    btn.addEventListener('click', function() {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  }
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  if (mobileBtn && mobileMenu) {
    mobileBtn.addEventListener('click', function() {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
