---
const siteName = "PlainLayoffs";
const currentYear = new Date().getFullYear();

const exploreLinks = [
  { href: '/employers/', label: 'Top Employers' },
  { href: '/states/', label: 'Browse by State' },
  { href: '/industries/', label: 'By Industry' },
  { href: '/rankings', label: 'Rankings' },
  { href: '/recent', label: 'Recent Notices' },
  { href: '/ai-layoffs', label: 'AI-Caused Layoffs' },
];

const legal = [
  { href: '/about', label: 'About' },
  { href: '/privacy', label: 'Privacy Policy' },
  { href: '/terms', label: 'Terms of Use' },
  { href: '/contact', label: 'Contact' },
];

const guides = [
  { href: '/guides/warn-act-employee-rights', label: 'Understanding the WARN Act' },
  { href: '/guides/understanding-mass-layoffs', label: 'AI and Layoffs: What Data Shows' },
  { href: '/guides/surviving-a-layoff', label: 'What to Do When You Get WARN Notice' },
];
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-card)] mt-auto">
  <div class="container py-16 md:py-20">
    <div class="grid grid-cols-2 md:grid-cols-12 gap-8">
      <div class="col-span-2 md:col-span-4">
        <div class="flex items-center gap-2 font-semibold text-lg mb-3 text-amber-600 dark:text-amber-400">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          {siteName}
        </div>
        <p class="text-sm text-[var(--color-muted)] max-w-xs leading-relaxed">
          Mass layoff intelligence from WARN Act filings. Track employer layoff history, state trends, and worker impact data.
        </p>
        <p class="text-xs text-[var(--color-muted)] mt-3">
          Data sources: CA EDD WARN reports, publicly documented WARN filings. Not legal advice.
        </p>
      </div>

      <div class="col-span-1 md:col-span-2 md:col-start-6">
        <h3 class="text-xs font-semibold text-[var(--color-foreground)] uppercase tracking-wider mb-4">Explore</h3>
        <ul class="space-y-2.5">
          {exploreLinks.map(item => (
            <li>
              <a href={item.href} class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="col-span-1 md:col-span-3">
        <h3 class="text-xs font-semibold text-[var(--color-foreground)] uppercase tracking-wider mb-4">Guides</h3>
        <ul class="space-y-2.5">
          {guides.map(item => (
            <li>
              <a href={item.href} class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="col-span-1 md:col-span-2">
        <h3 class="text-xs font-semibold text-[var(--color-foreground)] uppercase tracking-wider mb-4">Company</h3>
        <ul class="space-y-2.5">
          {legal.map(item => (
            <li>
              <a href={item.href} class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-[var(--color-border)] mt-12 pt-8 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-sm text-[var(--color-muted)]">
        © {currentYear} {siteName} · Built by <a href="https://kiznis.studio" class="hover:text-[var(--color-foreground)] transition-colors">Kiznis.Studio</a>
      </p>
      <p class="text-xs text-[var(--color-muted)]">
        Data from public WARN Act filings. For informational purposes only.
      </p>
    </div>
  </div>
</footer>
